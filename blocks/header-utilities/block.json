{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jardin-theme/header-utilities",
	"title": "Header utilities",
	"category": "widgets",
	"icon": "admin-customizer",
	"description": "Language switcher, menu, search, theme, music, and support — header row or mobile drawer.",
	"textdomain": "jardin-theme",
	"attributes": {
		"variant": {
			"type": "string",
			"default": "header"
		}
	},
	"supports": {
		"html": false,
		"customClassName": true,
		"spacing": {
			"margin": true
		}
	},
	"render": "file:./render.php"
}
