# Playwright (phase 5). Copy to .env in repo root and adjust.
# See jardin-docs/tests-strategy.md

E2E_BASE_URL=https://dev.jasonrouet.com

# Polylang EN home (set E2E_SKIP_EN=1 if /en/ not ready)
# E2E_EN_PATH=/en/
# E2E_SKIP_EN=0

# A11y: set to 1 to fail on "serious" + "critical" (default: critical only)
# E2E_A11Y_STRICT=0

# Optional: HTTP Basic (staging behind auth)
# E2E_HTTP_USER=
# E2E_HTTP_PASS=
